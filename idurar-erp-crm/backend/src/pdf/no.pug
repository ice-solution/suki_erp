doctype html
html
  head
    meta(charset="utf-8")
    link(rel="shortcut icon" type="image/png" href="/images/icons/favicon.png")
    meta(name="viewport" content="width=device-width, initial-scale=1")
    style.
      .sheet { margin: 0; width: 100%; min-height: 297mm; box-sizing: border-box; }
      body { width: 100%; max-width: 100%; margin: 0; padding: 10px 16px 14px; background: #fff; font-family: Arial, sans-serif; font-size: 10px; color: #222; box-sizing: border-box; }
      *, *:before, *:after { box-sizing: border-box; color: #222; }

      .header-section { width: 100%; margin-bottom: 10px; }
      .header-top-row { width: 100%; text-align: right; margin-bottom: 2px; }
      .header-page { font-size: 8px; color: #666; }
      .header-company-wrap { width: 100%; text-align: center; margin-bottom: 8px; }
      .company-name-qu { font-size: 1.8em; font-weight: bold; line-height: 1.3; letter-spacing: 0.2em; }
      .company-name-qu-english { font-size: 1.2em; color: #222; margin-top: 2px; }

      .header-info-table { width: 100%; border-collapse: collapse; table-layout: fixed; }
      .header-info-table td { vertical-align: top; font-size: 10px; }
      .header-info-table .info-left { width: 55%; padding: 0 12px 0 0; text-align: left; }
      .header-info-table .info-right { width: 45%; text-align: right; padding: 0 0 0 12px; }
      .header-info-row { margin-bottom: 4px; }

      .sub-info { margin: 8px 0 6px; }
      .sub-info-row { margin-bottom: 4px; }

      .doc-title { text-align: center; font-size: 13px; font-weight: bold; margin: 10px 0 8px; color: #222; }

      .items-table { width: 100%; border-collapse: collapse; margin: 6px 0 10px; font-size: 10px; table-layout: fixed; }
      .items-table thead tr { border-top: 1px solid #222; border-bottom: 1px solid #222; }
      .items-table tbody tr { border-bottom: 1px solid #222; }
      .items-table th, .items-table td { padding: 6px 8px; vertical-align: top; }
      .items-table th { font-weight: bold; text-align: center; }
      .items-table .col-no { width: 6%; text-align: center; }
      .items-table .col-content { width: 74%; text-align: left; word-wrap: break-word; word-break: break-word; white-space: pre-wrap; }
      .items-table .col-qty { width: 20%; text-align: right; white-space: nowrap; }

      .ack-section { margin-top: 24px; }
      .ack-right { width: 28%; margin-left: auto; text-align: left; }
      .ack-title { font-weight: bold; margin-bottom: 6px; }
      .ack-row { display: flex; gap: 10px; align-items: flex-end; margin-bottom: 10px; }
      .ack-label { min-width: 70px; font-weight: bold; }
      .ack-line { flex: 1; border-bottom: 1px solid #222; height: 18px; }

      .end-marker { text-align: center; font-weight: bold; margin: 14px 0 6px; font-size: 10px; }
      .footer-section { margin-top: 16px; padding-top: 8px; border-top: 1px solid #ddd; text-align: center; font-size: 9px; color: #666; line-height: 1.5; }
      .footer-line-1 { margin-bottom: 2px; }
      .footer-line-2 { }

  body
    - const client = model.client || (model.clients && model.clients[0]) || {}
    - const displayName = model.receiptDisplayName || client.name || ''
    - const siteAddress = model.address || client.address || ''
    - const deliveryAddress = model.receiptDisplayName || ''
    - const consignee = model.receiver || ''
    - const poNumber = model.poNumber || ''
    - const docDate = model.date ? moment(model.date).utcOffset(480).format('DD/MM/YYYY') : ''
    - const invoiceNo = (model.numberPrefix || 'NO') + '-' + (model.number || '')
    - const quoteNo = model.invoiceNumber || ''
    - const itemsOnly = model.items || []

    .header-section
      .header-top-row
        .header-page Page 1
      .header-company-wrap
        .company-name-qu 永 順 鐵 器 工 程 公 司
        .company-name-qu-english Wing Shun Metal Eng Co (O/B Super Pioneer Ltd)
      table.header-info-table
        tr
          td.info-left
            .header-info-row TO : #{displayName}
            if siteAddress
              .header-info-row 地盤地址 : #{siteAddress}
          td.info-right
            .header-info-row
              | Invoice NO :
              // 用透明佔位，讓右對齊時「Invoice NO :」的起點對齊「報價編號 :」的標籤
              span(style="visibility:hidden;") #{invoiceNo}
            .header-info-row 報價編號 : #{quoteNo}
            .header-info-row Your P/O NO : #{poNumber}

      .sub-info
        if deliveryAddress
          .sub-info-row 送貨地址 : #{deliveryAddress}
        if consignee
          .sub-info-row 收 貨 人 : #{consignee}
        if docDate
          .sub-info-row 日　　期 : #{docDate}
        .sub-info-row 上單編號 : #{invoiceNo}

    .doc-title 發收單

    table.items-table
      thead
        tr
          th.col-no
          th.col-content 工程內容
          th.col-qty 數量
      tbody
        each item, idx in itemsOnly
          tr
            td.col-no #{idx + 1}
            td.col-content #{item.itemName || ''}#{item.description ? ' ' + item.description : ''}
            td.col-qty #{item.quantity != null ? item.quantity : ''}#{item.unit ? ' / ' + item.unit : ' / Job'}
        if itemsOnly.length === 0
          tr
            td(colspan='3' style='text-align:center') 無項目

    .ack-section
      .ack-right
        .ack-title 發收人：
        .ack-row
          .ack-label 裝箱方式：
          .ack-line
        .ack-row
          .ack-label 發收人：
          .ack-line
        .ack-row
          .ack-label 日　期：
          .ack-line

    .end-marker End

    .footer-section
      .footer-line-1 新界火炭坳背灣街14-24號金豪工業大廈第2期14樓G&H室 電話: 2776 4793, 2756 7579 傳真: 2776 4796
      .footer-line-2 Flat G&H, 14/F, Phase 2, Kin Ho Ind. Bldg., 14-24 Au Pui Wan St., Fotan, N.T. Tel: 2776 4793, 2756 7579 Fax: 2776 4796
