doctype html
html
  head
    link(rel="shortcut icon" type="image/png" href="/images/icons/favicon.png")
    meta(name="viewport" content="width=device-width, initial-scale=1")
    style.
      /* 讓整頁內容更貼頂，避免上方空白過多 */
      @page { margin: 0; }
      .sheet {
        margin: 0;
        width: 100%; 
        height: 297mm;
      }

      body{
        width: 100%; 
        margin: 0;
        padding: 20px 20px 0px;
        background: #ffffff;
        font-family: Arial, sans-serif;
        font-size:12px;
        color:#222;
      }
      *, *:before, *:after {
        box-sizing: inherit;
        color:#222
      }

      .clearfix {
        display: block; }
      .clearfix:after {
        content: "";
        display: table;
        clear: both;
      }
      .left{
        float:left;
      }
      .right{
        float:right;
      }
      
      .header-section.supermax-header-banner {
        width: 100%;
        margin-bottom: 20px;
      }
      .supermax-header-banner img {
        width: 100%;
        height: auto;
        display: block;
      }
      
      .document-title {
        text-align: center;
        font-size: 24px;
        font-weight: bold;
        margin: 30px 0;
        color: #222;
      }
      
      .info-section { width: 100%; margin-bottom: 16px; font-size: 10px; }
      .info-table { width: 100%; border-collapse: collapse; table-layout: fixed; }
      .info-table td { vertical-align: top; font-size: 10px; }
      .info-table .info-left { width: 55%; padding: 0 12px 0 0; text-align: left; }
      .info-table .info-right { width: 45%; text-align: right; padding: 0 0 0 12px; }
      .info-row { margin-bottom: 4px; }
      
      .table-container {
        width: 100%;
        margin: 20px 0;
      }
      
      .items-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 20px;
      }
      
      .items-table th {
        background-color: #f0f0f0;
        border: 1px solid #ddd;
        padding: 10px;
        text-align: left;
        font-weight: bold;
        font-size: 12px;
      }
      
      .items-table td {
        border: 1px solid #ddd;
        padding: 10px;
        font-size: 12px;
      }
      
      .items-table .item-name {
        width: 35%;
      }
      
      .items-table .item-desc {
        width: 45%;
        word-wrap: break-word;
        word-break: break-word;
        white-space: pre-wrap;
      }
      
      .items-table .item-qty {
        width: 20%;
        text-align: center;
      }
      
      .items-table .item-unit {
        width: 20%;
        text-align: center;
      }
      
      .acknowledgement-section {
        margin-top: 40px;
        width: 100%;
      }
      
      .acknowledgement-title {
        text-align: center;
        font-size: 20px;
        font-weight: bold;
        margin-bottom: 20px;
      }
      
      .acknowledgement-info {
        display: flex;
        justify-content: space-around;
        margin-bottom: 30px;
      }
      
      .acknowledgement-item {
        text-align: center;
      }
      
      .acknowledgement-label {
        font-weight: bold;
        margin-bottom: 10px;
        font-size: 12px;
      }
      
      .acknowledgement-line {
        border-bottom: 1px solid #222;
        width: 150px;
        height: 30px;
        margin: 0 auto;
      }
      
      .footer-section {
        margin-top: 40px;
        text-align: center;
        padding: 0;
        border-top: none;
        transform: translateY(-20px);
      }
      .footer-section img {
        width: 70%;
        max-width: 70%;
        height: auto;
        display: block;
        margin: 0 auto;
      }

body
  .header-section.supermax-header-banner
    img(src=settings.public_server_file+'uploads/images/header_001.png' alt='')

  .document-title 簽收單

  .info-section
    - const client = model.client || (model.clients && model.clients[0]) || {}
    - const displayName = model.receiptDisplayName || client.name || ''
    table.info-table
      tr
        td.info-left
          .info-row 客戶: #{displayName}
          .info-row 客戶地址: #{client.address || ''}
          if model.address
        td.info-right
          .info-row 檔案編號 : #{model.invoiceNumber || (model.numberPrefix || 'SWP') + '-' + model.number + '/' + (model.year || '')}
          .info-row 日期 : #{moment(model.date).utcOffset(480).format('DD-MM-YYYY')}

  .table-container
    table.items-table
      thead
        tr
          th.item-name 項目
          th.item-desc 描述
          th.item-qty 數量
      tbody
        - const itemsOnly = model.items || []
        each item in itemsOnly
          tr
            td.item-name #{item.itemName || ''}
            td.item-desc #{item.description || ''}
            td.item-qty #{item.quantity != null ? item.quantity : ''}
        if itemsOnly.length === 0
          tr
            td(colspan='3' style='text-align: center;') 無項目

  .acknowledgement-section
    .acknowledgement-title 簽收單
    .acknowledgement-info
      .acknowledgement-item
        .acknowledgement-label 裝箱方式
        .acknowledgement-line
      .acknowledgement-item
        .acknowledgement-label 簽收人
        .acknowledgement-line
      .acknowledgement-item
        .acknowledgement-label 日期
        .acknowledgement-line

  .footer-section
    img(src=settings.public_server_file+'uploads/images/footer_001.png' alt='')
