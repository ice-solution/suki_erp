doctype html
html(class=isPuppeteer ? 'puppeteer-ship-quote-rental' : '')
  head
    meta(charset="utf-8")
    link(rel="shortcut icon" type="image/png" href="/images/icons/favicon.png")
    meta(name="viewport" content="width=device-width, initial-scale=1")
    style.
      /* 讓整頁內容更貼頂，避免上方空白過多 */
      @page { margin: 0; }
      body { width: 100%; max-width: 100%; margin: 0; padding: 20px 16px 10px; background: #fff; font-family: Arial, sans-serif; font-size: 10px; color: #222; box-sizing: border-box; }
      *, *:before, *:after { box-sizing: border-box; color: #222; }
      .footer-section { margin-top: 12px; padding: 0; border-top: none; text-align: center; box-sizing: border-box; transform: translateY(-20px); }
      .footer-section img { width: 70%; max-width: 70%; height: auto; display: block; margin: 0 auto; }
      .rental-page { display: block; page-break-inside: auto; }
      .rental-page + .rental-page { page-break-before: always; }
      .rental-page-body { display: block; position: relative; padding-bottom: 18px; }
      .supermax-header-banner { width: 100%; margin-bottom: 6px; }
      .supermax-header-banner img { width: 100%; height: auto; display: block; }
      /* 頁碼移至右下角（每頁） */
      .page-number-bottom { position: absolute; right: 0; bottom: 0; font-size: 8px; color: #666; }
      .info-table-ship { width: 100%; border-collapse: collapse; table-layout: fixed; margin-bottom: 6px; font-size: 10px; }
      .info-table-ship td { vertical-align: top; }
      .info-table-ship .info-left { width: 55%; padding: 0 12px 0 0; text-align: left; }
      .info-table-ship .info-right { width: 45%; text-align: right; padding: 0 0 0 12px; }
      .info-row { margin-bottom: 2px; }
      .info-row-indent { margin-left: 20px; }
      .doc-title { text-align: center; font-size: 13px; font-weight: bold; margin: 4px 0 4px; color: #222; }
      .project-contact-line { margin-bottom: 2px; font-size: 10px; text-align: left; }
      .project-address-line { margin-bottom: 4px; font-size: 10px; text-align: left; }
      .quotation-table { width: 100%; border-collapse: collapse; margin: 6px 0; font-size: 10px; table-layout: fixed; }
      .quotation-table th, .quotation-table td { border: none; padding: 6px 8px; vertical-align: top; }
      .quotation-table thead tr { border-top: 1px solid #222; border-bottom: 1px solid #222; }
      .quotation-table tbody tr { border-bottom: 1px solid #222; }
      .quotation-table th { background: transparent; font-weight: bold; font-size: 10px; text-align: center; }
      .quotation-table .col-no { width: 6%; text-align: center; }
      .quotation-table .col-content { width: 44%; word-wrap: break-word; word-break: break-word; text-align: left; white-space: pre-wrap; }
      .quotation-table .col-qty { width: 16%; text-align: center; white-space: nowrap; }
      .quotation-table .col-unit { width: 16%; text-align: right; white-space: nowrap; }
      .quotation-table .col-amount { width: 18%; text-align: right; white-space: nowrap; }
      .quotation-table td.num { text-align: right; }
      /* 單筆工程內容極長時允許列跨頁，避免整頁被「不穿頁」撐爆 */
      .quotation-table tbody tr { page-break-inside: auto; break-inside: auto; }
      .quotation-table tbody td { page-break-inside: auto; break-inside: auto; vertical-align: top; }
      .summary-wrap { margin-top: 8px; display: flex; justify-content: flex-end; }
      .summary-block { text-align: right; font-size: 10px; }
      .summary-row { margin-bottom: 4px; }
      .summary-label { font-weight: bold; display: inline-block; min-width: 90px; text-align: right; padding-right: 8px; }
      .summary-value { display: inline-block; min-width: 100px; text-align: right; }
      .summary-row.subtotal .summary-value { text-decoration: underline; }
      .summary-row.underline .summary-value { text-decoration: underline; }
      .summary-row.grand .summary-value { font-weight: bold; text-decoration: underline; }
      .notes-block { margin-top: 8px; font-size: 10px; line-height: 1.5; }
      .notes-title { font-weight: bold; margin-bottom: 2px; }
      .notes-content { white-space: pre-wrap; word-wrap: break-word; }
      .extra-section { margin-top: 12px; }
      /* 合計緊接最後一頁明細，避免空白仍強制換頁 */
      .summary-wrap { page-break-inside: avoid; break-inside: avoid; }
      /* 附加項目：與合計／條款分開，新頁開始 */
      .rental-page-after-items { page-break-before: always; break-before: page; }
      .extra-section-block { page-break-inside: avoid; break-inside: avoid; }
      .extra-table { width: 100%; border-collapse: collapse; margin: 8px 0; font-size: 10px; page-break-inside: auto; }
      .extra-table caption.extra-section-caption {
        caption-side: top;
        text-align: left;
        font-weight: bold;
        margin: 0 0 4px;
        padding: 0;
        page-break-after: avoid;
        break-after: avoid;
      }
      .extra-table th, .extra-table td { border: none; padding: 4px 8px; text-align: left; border-bottom: 1px solid #ddd; }
      .extra-table th { background: transparent; font-weight: bold; }
      .extra-table .col-no { width: 6%; text-align: center; white-space: nowrap; }
      .extra-table .col-desc { width: auto; white-space: pre-wrap; word-break: break-word; }
      .extra-table .col-price { text-align: right; width: 160px; white-space: nowrap; }
      .terms-section { margin: 12px 0; font-size: 10px; line-height: 1.6; }
      .terms-section h4 { margin: 8px 0 4px; font-size: 10px; }
      .terms-section ol { margin: 0; padding-left: 18px; }
      .terms-section li { margin-bottom: 4px; }
      .rental-description-content { margin: 4px 0 10px; white-space: pre-wrap; word-break: break-word; }
      .signature-section { margin-top: 12px; }
      .signature-table { width: 100%; border-collapse: collapse; table-layout: fixed; }
      .signature-table td { vertical-align: top; font-size: 10px; }
      .signature-table .sig-left { width: 50%; padding-right: 24px; text-align: left; }
      .signature-table .sig-right { width: 50%; padding-left: 24px; text-align: right; }
      .prepared-by-row { margin-bottom: 10px; font-size: 10px; }
      .prepared-by-label { font-weight: bold; display: inline-block; margin-right: 8px; }
      .prepared-by-space { display: inline-block; min-width: 120px; height: 20px; vertical-align: middle; }
      .issuer-block { display: inline-block; text-align: left; }
      .issuer-name-line { font-size: 9px; font-weight: bold; margin-bottom: 4px; }
      .issuer-stamp { border-bottom: 1px solid #222; width: 180px; height: 40px; margin-top: 4px; }
      .signature-stamp-label { font-size: 9px; margin-top: 4px; }
      .end-marker { text-align: center; font-weight: bold; margin: 8px 0 4px; font-size: 10px; }
    if isPuppeteer
      style.
        /* Puppeteer：頁尾改由 page.pdf 的 footerTemplate 繪製，避免出現雙 footer */
        html.puppeteer-ship-quote-rental .footer-section { display: none !important; }
  body
    - const client = model.client || (model.clients && model.clients[0]) || {}
    - const clientName = client.name || ''
    - const clientAddressPdf = (client.address || '').replace(/\r\n|\n|\r/g, ' ').trim()
    - const projectAddressPdf = (model.address || '').replace(/\r\n|\n|\r/g, ' ').trim()
    - const contactPersonPdf = (model.contactPerson != null && String(model.contactPerson).trim()) ? String(model.contactPerson).trim() : ''
    - const docNumber = (model.numberPrefix || 'S') + '-' + model.number
    - const docDate = model.date ? moment(model.date).utcOffset(480).format('DD/MM/YYYY') : ''
    - const itemsOnly = model.items || []
    -
      // 吊船租賃 PDF：僅估算 tbody「工程內容」欄；過緊會提早分頁；可用 SHIPQUOTE_PDF_BODY_LINE_CAP 覆寫 tbody 行數上限
      const capFromEnv = typeof shipPdfBodyLineCap === 'number' && shipPdfBodyLineCap > 0 ? shipPdfBodyLineCap : null
      const S_PDF_MAX_LINES_PER_PAGE = 26
      const S_PDF_CHARS_PER_LINE = 34
      const S_PDF_SAFETY_FACTOR = 1
      const S_PDF_ROW_PAD = 0
      const S_PDF_SHIP_PAGE_HEADER_COST = 2
      const S_PDF_ITEM_BODY_LINE_CAP = capFromEnv != null ? capFromEnv : Math.max(20, S_PDF_MAX_LINES_PER_PAGE - S_PDF_SHIP_PAGE_HEADER_COST)
      function buildItemContentText(item) {
        const name = (item.itemName || '').replace(/^\s*\d+[\.\)]?\s*/, '').trim()
        const desc = item.description ? ' ' + item.description : ''
        return (name + desc).trim() || '-'
      }
      function estimateItemContentLines(item) {
        let text = String(buildItemContentText(item)).replace(/^\s+/, '').replace(/\s+$/, '')
        if (!text || text === '-') return 1 + S_PDF_ROW_PAD
        let lines = 0
        const parts = text.split(/\r\n|\n|\r/)
        for (let pi = 0; pi < parts.length; pi++) {
          const seg = parts[pi]
          if (seg.length === 0) {
            lines += 1
            continue
          }
          lines += Math.max(1, Math.ceil(seg.length / S_PDF_CHARS_PER_LINE))
        }
        return Math.max(1, Math.ceil(lines * S_PDF_SAFETY_FACTOR)) + S_PDF_ROW_PAD
      }
      const itemChunks = []
      let curChunk = []
      let curLines = 0
      for (let ii = 0; ii < itemsOnly.length; ii++) {
        const it = itemsOnly[ii]
        const L = estimateItemContentLines(it)
        if (curChunk.length > 0 && curLines + L > S_PDF_ITEM_BODY_LINE_CAP) {
          itemChunks.push(curChunk)
          curChunk = []
          curLines = 0
        }
        curChunk.push(it)
        curLines += L
      }
      if (curChunk.length > 0) itemChunks.push(curChunk)
      if (itemChunks.length === 0) itemChunks.push([])
      // 附加項目分頁：避免文字太多把簽署截斷
      const defaultRentalExtras = [
        { description: '續租-導向吊船 (GSWP-P1)', unitPrice: null },
        { description: '額外電源線(200米以外部份)', unitPrice: null },
        { description: '因井道漏水落雨整壞爬纜器,需更換爬纜器', unitPrice: null },
        { description: '因地盤非法使用嚴重超重,以導致爬纜器損壞需更換爬纜器', unitPrice: null },
        { description: '吊船改吊點重新安排檢驗F2/F3證書', unitPrice: null },
        { description: '三角足場續租(每14日)', unitPrice: null },
      ]
      const rentalRowsRaw = (model.rentalExtraItems && model.rentalExtraItems.length) ? model.rentalExtraItems : defaultRentalExtras
      const rentalRowsAll = rentalRowsRaw.slice().sort((a, b) => (a.sortOrder || 0) - (b.sortOrder || 0))
      const EXTRA_CHARS_PER_LINE = 40
      const EXTRA_SAFETY_FACTOR = 1.2
      const EXTRA_MAX_LINES_PER_PAGE = 28
      function estimateExtraRowLines(row) {
        const text = (row && row.description) ? String(row.description) : ''
        let lines = 0
        const parts = String(text).split(/\r\n|\n|\r/)
        for (let pi = 0; pi < parts.length; pi++) {
          const seg = parts[pi]
          lines += Math.max(1, Math.ceil(seg.length / EXTRA_CHARS_PER_LINE))
        }
        // +1：表格 padding / row 間距緩衝
        return Math.ceil(lines * EXTRA_SAFETY_FACTOR) + 1
      }
      const extraChunks = []
      let curExtra = []
      let curExtraLines = 0
      for (let ei = 0; ei < rentalRowsAll.length; ei++) {
        const row = rentalRowsAll[ei]
        const L = estimateExtraRowLines(row)
        if (curExtra.length > 0 && curExtraLines + L > EXTRA_MAX_LINES_PER_PAGE) {
          extraChunks.push(curExtra)
          curExtra = []
          curExtraLines = 0
        }
        curExtra.push(row)
        curExtraLines += L
      }
      if (curExtra.length > 0) extraChunks.push(curExtra)
      if (extraChunks.length === 0) extraChunks.push([])
    - const subTotal = model.subTotal != null ? model.subTotal : itemsOnly.reduce((s, i) => s + (i.total != null ? i.total : (i.quantity || 0) * (i.price || 0)), 0)
    - const discount = model.discount != null ? model.discount : 0
    - const discountTotal = model.discountTotal != null ? model.discountTotal : (subTotal * discount / 100)
    - const total = model.total != null ? model.total : (subTotal - discountTotal)
    - const currency = model.currency || 'HKD'
    - var serialBase = 0
    - var extraSerialBase = 0

    each chunk, pageIndex in itemChunks
      .rental-page
        .rental-page-body
          .supermax-header-banner
            img(src=settings.public_server_file+'uploads/images/header_001.png' alt='')
          table.info-table-ship
            tr
              td.info-left
                .info-row TO : #{clientName}
                .info-row.info-row-indent #{clientAddressPdf || '-'}
                .info-row 聯絡人：#{contactPersonPdf || '-'}
              td.info-right
                .info-row 報價編號 : #{docNumber}
                .info-row 報價日期 : #{docDate}
          .doc-title 導向吊船租賃報價
          .project-address-line 工程地址：#{projectAddressPdf || '-'}
          table.quotation-table
            thead
              tr
                th.col-no
                th.col-content 工程內容
                th.col-qty 數量 / 單位
                th.col-unit 單價 HKD$
                th.col-amount 金額 HKD$
            tbody
              each item, idx in chunk
                - const contentText = (item.itemName || '').replace(/^\s*\d+[\.\)]?\s*/, '').trim() + (item.description ? ' ' + item.description : '')
                - const unitLabel = item.unit ? String(item.unit) : 'JOB'
                tr
                  td.col-no #{serialBase + idx + 1}
                  td.col-content #{contentText}
                  td.col-qty #{item.quantity != null ? item.quantity : ''} / #{unitLabel}
                  td.col-unit.num #{item.price != null ? moneyFormatter({ amount: item.price, currency_code: currency }) + ' / ' + unitLabel : ''}
                  td.col-amount.num #{item.total != null ? moneyFormatter({ amount: item.total, currency_code: currency }) : (item.price != null && item.quantity != null ? moneyFormatter({ amount: item.price * item.quantity, currency_code: currency }) : '')}
              if chunk.length === 0
                tr
                  td(colspan='5' style='text-align:center') 無項目
          - serialBase += chunk.length
          if pageIndex === itemChunks.length - 1
            .summary-wrap
              .summary-block
                .summary-row.subtotal
                  span.summary-label 合共港幣：
                  span.summary-value #{moneyFormatter({ amount: subTotal, currency_code: currency })}
                if model.showDiscountPercentOnPdf !== false
                  .summary-row.underline
                    span.summary-label 折扣%：
                    span.summary-value #{formatDiscountPct(discount)}%
                if model.showDiscountAmountOnPdf !== false
                  .summary-row.underline
                    span.summary-label 折扣金額：
                    span.summary-value #{formatDiscountMoneyForPdf(discountTotal, settings)}
                .summary-row.grand
                  span.summary-label 總金額：
                  span.summary-value #{moneyFormatter({ amount: total, currency_code: currency })}
            .notes-block
              .notes-content
                if model.notes
                  | #{model.notes}
        unless isPuppeteer
          .footer-section
            img(src=settings.public_server_file+'uploads/images/footer_001.png' alt='')

    //- 附加項目：按長度分頁（每頁同樣頁首；Puppeteer 模式下 footer-section 會被隱藏）
    each extraChunk, extraPageIndex in extraChunks
      .rental-page.rental-page-after-items
        .rental-page-body
          .supermax-header-banner
            img(src=settings.public_server_file+'uploads/images/header_001.png' alt='')
          table.info-table-ship
            tr
              td.info-left
                .info-row TO : #{clientName}
                .info-row.info-row-indent #{clientAddressPdf || '-'}
                .info-row 聯絡人：#{contactPersonPdf || '-'}
              td.info-right
                .info-row 報價編號 : #{docNumber}
                .info-row 報價日期 : #{docDate}
          .doc-title 導向吊船租賃報價
          .project-address-line 工程地址：#{projectAddressPdf || '-'}
          .extra-section
            .extra-section-block
              table.extra-table
                caption.extra-section-caption 附加項目
                thead
                  tr
                    th.col-no
                    th.col-desc 摘要
                    th.col-price 單價/單位 HKD $
                tbody
                  each row, extraIdx in extraChunk
                    - const desc = (row && row.description) ? row.description : ''
                    - const unitLabel = (row && row.unit) ? String(row.unit) : ''
                    - const up = row && row.unitPrice
                    tr
                      td.col-no #{extraSerialBase + extraIdx + 1}
                      td.col-desc #{desc}
                      td.col-price.num
                        if up != null && up !== '' && !isNaN(Number(up))
                          | #{moneyFormatter({ amount: Number(up), currency_code: currency })}/#{unitLabel || '-'}
                        else
                          | -
          - extraSerialBase += extraChunk.length
          unless isPuppeteer
            .footer-section
              img(src=settings.public_server_file+'uploads/images/footer_001.png' alt='')

    //- 租賃說明 + 簽署：固定獨立最後一頁，避免被附加項目擠到截斷
    .rental-page
      .rental-page-body
        .supermax-header-banner
          img(src=settings.public_server_file+'uploads/images/header_001.png' alt='')
        table.info-table-ship
          tr
            td.info-left
              .info-row TO : #{clientName}
              .info-row.info-row-indent #{clientAddressPdf || '-'}
              .info-row 聯絡人：#{contactPersonPdf || '-'}
            td.info-right
              .info-row 報價編號 : #{docNumber}
              .info-row 報價日期 : #{docDate}
        .doc-title 導向吊船租賃報價
        .project-address-line 工程地址：#{projectAddressPdf || '-'}
        .terms-section
          h4 租賃說明
          - const rentalDescCustom = model.rentalDescription && String(model.rentalDescription).trim()
          if rentalDescCustom
            .rental-description-content #{rentalDescCustom}
          else
            ol
              li 租用價格包括吊船交機及來回運輸費用(不包括離島地區)。
              li 由確定收到租金起計, 90天後送貨。
              li 價格第二及三項為消耗品, 恕不提供租用服務。
              li 租用期間本公司會提供免費自然損耗的維修及使用方法支援(不包括人為損壞)。
              li 預約維修由收到租用者通知24小時內安排修理, 維修工作時間為星期一到六9:00-17:00, 法定假日順延一天。
              li 租用期間如因壞機而影響地盤工作, 本公司可恕不負責。
              li 地盤吊船負荷測試及檢驗證明書(FORM3)需要由租方負責(本公司會提供協助完成)。
              li 在吊船上工作人員須持有吊船工作人員證書或已接受相關訓練。
              li 租用者必須安全正確方法操作, 不應超載負荷或改裝, 否則本公司有權禁止使用。
              li 所有地盤使用人員及第三者保險由租用者負責。
              li 租用者須維持租用吊船原樣及完整, 如有遺失及損壞, 照價賠償。
          - const defaultPdfPayment = '租賃合約確定須先付全數租金, 其他配件及費用裝設完成付款。'
          - const pdfPaymentText = (model.pdfPaymentMethod != null && String(model.pdfPaymentMethod).trim()) ? String(model.pdfPaymentMethod).trim() : defaultPdfPayment
          - const defaultPdfValidity = model.expiredDate ? moment(model.expiredDate).utcOffset(480).format('DD-MM-YYYY') + ' 或 90天' : '90天'
          - const pdfValidityText = (model.pdfQuoteValidity != null && String(model.pdfQuoteValidity).trim()) ? String(model.pdfQuoteValidity).trim() : defaultPdfValidity
          h4 付款方法
          p(style='white-space: pre-wrap; word-break: break-word;') #{pdfPaymentText}
          h4 報價有效期
          p(style='white-space: pre-wrap; word-break: break-word;') #{pdfValidityText}
        .signature-section
          .prepared-by-row
            span.prepared-by-label 制單人：
            if model.updatedBy && model.updatedBy.name
              span #{model.updatedBy.name}
            else if model.createdBy && model.createdBy.name
              span #{model.createdBy.name}
            else
              span.prepared-by-space
          table.signature-table
            tr
              td.sig-left
                .issuer-block
                  .issuer-name-line 核實者
                  .issuer-name-line 同意及確定
                  .issuer-stamp
                  .signature-stamp-label 公司簽署及蓋章
              td.sig-right
                .issuer-block
                  .issuer-name-line 發出者
                  .issuer-name-line 超越工程公司
                  .issuer-stamp
                  .signature-stamp-label 公司簽署及蓋章
        .end-marker End
      unless isPuppeteer
        .footer-section
          img(src=settings.public_server_file+'uploads/images/footer_001.png' alt='')
