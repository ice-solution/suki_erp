doctype html
html
  head
    link(rel="shortcut icon" type="image/png" href="/images/icons/favicon.png")
    meta(name="viewport" content="width=device-width, initial-scale=1")
    style.
      .sheet {
        margin: 0;
        width: 100%; 
        height: 297mm;
      }

      body {
        width: 100%;
        max-width: 100%;
        margin: 0;
        padding: 6px 16px 10px;
        background: #fff;
        font-family: Arial, sans-serif;
        font-size: 10px;
        color: #222;
        box-sizing: border-box;
      }
      *, *:before, *:after {
        box-sizing: inherit;
        color:#222
      }

      .clearfix {
        display: block; }
      .left{
        float:left;
      }
      .right{
        float:right;
      }
      .top-area {    
        display: block;
        width:100%;
        
      }
      alignRight :{
        text-align: right !important;
      }
      alignLeft :{
        text-align: left;
      }
      .logo {
        width: 150px;
      }
      .company-info{
        text-align: right;
        font-size:12px;
      }
      h1.invoice{
        font-size:32px;
        color:#52008c;
        margin-top:0;
      }
      p.strong{
        font-weight:700;
      }
      .billTo p {
        text-align: left !important;
        display:block;
        font-size:12px;
        width:100%;
        margin-top:0;
        margin-bottom:10px;
        
      }

      .tableHeader{
        color:#52008c;
      }
      .clearfix {
        display: block; }
      .col {
        float:left;
      }
      .col-1 {
        width: 4.16667%; }

      .col-2 {
        width: 8.33333%; }

      .col-3 {
        width: 12.5%; }

      .col-4 {
        width: 16.66667%; }

      .col-5 {
        width: 20.83333%; }

      .col-6 {
        width: 25%; }

      .col-7 {
        width: 29.16667%; }

      .col-8 {
        width: 33.33333%; }

      .col-9 {
        width: 37.5%; }

      .col-10 {
        width: 41.66667%; }

      .col-11 {
        width: 45.83333%; }

      .col-12 {
        width: 50%; }

      .col-13 {
        width: 54.16667%; }

      .col-14 {
        width: 58.33333%; }

      .col-15 {
        width: 62.5%; }

      .col-16 {
        width: 66.66667%; }

      .col-17 {
        width: 70.83333%; }

      .col-18 {
        width: 75%; }

      .col-19 {
        width: 79.16667%; }

      .col-20 {
        width: 83.33333%; }

      .col-21 {
        width: 87.5%; }

      .col-22 {
        width: 91.66667%; }

      .col-23 {
        width: 95.83333%; }

      .col-24 {
        width: 100%; }
      .space {
        margin-top: 30px;
        margin-bottom: 40px;
        width:100%;
      }
      .footer-section { margin-top: 12px; padding-top: 6px; border-top: 1px solid #ddd; text-align: center; font-size: 9px; color: #666; line-height: 1.5; }
      .footer-line-1 { margin-bottom: 2px; }
      .footer-line-2 { }
      .sml-page { display: block; page-break-inside: auto; }
      .sml-page + .sml-page { page-break-before: always; }
      .sml-page-body { display: block; }
      .header-section { width: 100%; margin-bottom: 6px; }
      .header-table { width: 100%; border-collapse: collapse; table-layout: fixed; }
      .header-table td { vertical-align: top; }
      .header-table td.header-left { width: 67%; padding: 0 8px 0 0; }
      .header-table td.header-right { width: 33%; text-align: right; padding: 0 0 0 8px; }
      .header-left-inner { display: table; width: 100%; table-layout: fixed; }
      .header-logo-cell { width: 100px; padding-right: 12px; vertical-align: top; }
      .header-logo { width: 100px; height: 100px; display: block; object-fit: contain; }
      .header-text-cell { vertical-align: top; width: auto; min-width: 0; }
      .company-name { font-family: "Times New Roman", Times, serif; font-size: 13px; font-weight: bold; line-height: 1.3; word-wrap: break-word; letter-spacing: 0.25em; }
      .company-name-english { font-family: "Times New Roman", Times, serif; font-size: 15px; font-weight: bold; color: #222; margin-top: 2px; white-space: nowrap; letter-spacing: 0; }
      .company-ownership { font-family: "Times New Roman", Times, serif; font-size: 10px; color: #222; margin-top: 2px; word-wrap: break-word; }
      .certification-section { font-size: 8px; color: #666; line-height: 1.4; }
      .certification-logos .iso-text { display: block; margin-top: 2px; }
      .header-page { margin-top: 2px; font-size: 8px; }
      .info-table-ship { width: 100%; border-collapse: collapse; table-layout: fixed; margin-bottom: 6px; font-size: 10px; }
      .info-table-ship td { vertical-align: top; }
      .info-table-ship .info-left { width: 55%; padding: 0 12px 0 0; text-align: left; }
      .info-table-ship .info-right { width: 45%; text-align: right; padding: 0 0 0 12px; }
      .info-row { margin-bottom: 2px; }
      .doc-title { text-align: center; font-size: 13px; font-weight: bold; margin: 4px 0 4px; color: #222; }
      .project-contact-line { margin-bottom: 2px; font-size: 10px; text-align: left; }
      .project-address-line { margin-bottom: 4px; font-size: 10px; text-align: left; }
      .quotation-table { width: 100%; border-collapse: collapse; margin: 6px 0; font-size: 10px; table-layout: fixed; }
      .quotation-table th, .quotation-table td { border: none; padding: 6px 8px; vertical-align: top; }
      .quotation-table thead tr { border-top: 1px solid #222; border-bottom: 1px solid #222; }
      .quotation-table tbody tr { border-bottom: 1px solid #222; }
      .quotation-table th { background: transparent; font-weight: bold; font-size: 10px; text-align: center; }
      .quotation-table .col-no { width: 6%; text-align: center; }
      .quotation-table .col-content { width: 44%; word-wrap: break-word; text-align: left; }
      .quotation-table .col-qty { width: 16%; text-align: center; white-space: nowrap; }
      .quotation-table .col-unit { width: 16%; text-align: right; white-space: nowrap; }
      .quotation-table .col-amount { width: 18%; text-align: right; white-space: nowrap; }
      .quotation-table td.num { text-align: right; }
      .summary-wrap { margin-top: 8px; display: flex; justify-content: flex-end; }
      .summary-block { text-align: right; font-size: 10px; }
      .summary-row { margin-bottom: 4px; }
      .summary-label { font-weight: bold; display: inline-block; min-width: 90px; text-align: right; padding-right: 8px; }
      .summary-value { display: inline-block; min-width: 100px; text-align: right; }
      .summary-row.subtotal .summary-value { text-decoration: underline; }
      .summary-row.grand .summary-value { font-weight: bold; text-decoration: underline; text-decoration-style: double; }
      .notes-block { margin-top: 8px; font-size: 10px; line-height: 1.5; }
      .notes-title { font-weight: bold; margin-bottom: 2px; }
      .signature-section { margin-top: 12px; }
      .signature-table { width: 100%; border-collapse: collapse; table-layout: fixed; }
      .signature-table td { vertical-align: top; font-size: 10px; }
      .signature-table .sig-left { width: 50%; padding-right: 24px; text-align: left; }
      .signature-table .sig-right { width: 50%; padding-left: 24px; text-align: right; }
      .prepared-by-row { margin-bottom: 10px; font-size: 10px; }
      .prepared-by-label { font-weight: bold; display: inline-block; margin-right: 8px; }
      .prepared-by-space { display: inline-block; min-width: 120px; height: 20px; vertical-align: middle; }
      .issuer-block { display: inline-block; text-align: left; }
      .issuer-name-line { font-size: 9px; font-weight: bold; margin-bottom: 4px; }
      .issuer-stamp { border-bottom: 1px solid #222; width: 180px; height: 40px; margin-top: 4px; }
      .signature-stamp-label { font-size: 9px; margin-top: 4px; }
      .end-marker { text-align: center; font-weight: bold; margin: 8px 0 4px; font-size: 10px; }

body
    - const client = model.client || (model.clients && model.clients[0]) || {}
    - const clientName = client.name || ''
    - const clientAddress = (client.address || model.address || '').replace(/\n/g, ' ')
    - const docNumber = model.invoiceNumber || (model.numberPrefix || 'SML') + '-' + model.number + '/' + (model.year || '')
    - const docDate = model.date ? moment(model.date).format('DD/MM/YYYY') : ''
    - const consigneeLine = model.contactPerson ? (client.phone ? model.contactPerson + ' ' + client.phone : model.contactPerson) : (client.phone || '')
    - const deliveryAddress = model.address || clientAddress || ''
    - const itemsOnly = model.items || []
    - const ITEMS_PER_PAGE = 8
    - const itemChunks = []
    - for (let i = 0; i < itemsOnly.length; i += ITEMS_PER_PAGE) { itemChunks.push(itemsOnly.slice(i, i + ITEMS_PER_PAGE)) }
    - if (itemChunks.length === 0) itemChunks.push([])
    - const subTotal = model.subTotal != null ? model.subTotal : itemsOnly.reduce((s, i) => s + (i.total != null ? i.total : (i.quantity || 0) * (i.price || 0)), 0)
    - const discount = model.discount != null ? model.discount : 0
    - const discountTotal = model.discountTotal != null ? model.discountTotal : (subTotal * discount / 100)
    - const total = model.total != null ? model.total : (subTotal - discountTotal)
    - const currency = model.currency || 'HKD'

    each chunk, pageIndex in itemChunks
      .sml-page(class=pageIndex === itemChunks.length - 1 ? 'sml-page-last' : '')
        .sml-page-body
          .header-section
            table.header-table
              tr
                td.header-left
                  table.header-left-inner
                    tr
                      td.header-logo-cell
                        img.header-logo(src=settings.public_server_file+settings.company_logo)
                      td.header-text-cell
                        .company-name 超越工程公司
                        .company-name-english SUPER MAX ENGINEERING CO.
                        .company-ownership (Wholly Owned By Super Pioneer Ltd.)
                td.header-right
                  .certification-section
                    .certification-logos
                      img.iso-cert-img(src=settings.public_server_file+'uploads/images/iso_img.png' alt='ISO' style='max-width:96px;height:auto;display:block;margin-bottom:4px;margin-left:auto;')
                      span.iso-text ISO 9001 : 2008
                      span.iso-text Certificate No : Q368
                  .header-page Page #{pageIndex + 1}
          table.info-table-ship
            tr
              td.info-left
                .info-row TO : #{clientName}
                .info-row #{model.shipType ? (model.address || clientAddress || '') : (clientAddress || '')}
                if !model.shipType && model.address
                  .info-row 工程地址：#{model.address}
              td.info-right
                .info-row 報價編號 : #{docNumber}
                .info-row 日期(Date) : #{docDate}
            if model.shipType
              tr
                td.info-left
                  .info-row 送貨地址: #{deliveryAddress || '-'}
                  .info-row 收貨人: #{consigneeLine || '-'}
                td.info-right
          .doc-title 導向吊船租賃報價
          if model.contactPerson
            .project-contact-line 聯絡人：#{model.contactPerson}
          if model.address
            .project-address-line 工程地址：#{model.address || ''}
          table.quotation-table
            thead
              tr
                th.col-no
                th.col-content 工程內容
                th.col-qty 數量 / Job
                th.col-unit 單價 HKD$
                th.col-amount 金額 HKD$
            tbody
              each item, idx in chunk
                - const contentText = (item.itemName || '').replace(/^\s*\d+[\.\)]?\s*/, '').trim() + (item.description ? ' ' + item.description : '')
                tr
                  td.col-no #{pageIndex * ITEMS_PER_PAGE + idx + 1}
                  td.col-content #{contentText}
                  td.col-qty #{item.quantity != null ? item.quantity : ''} / Job
                  td.col-unit.num #{item.price != null ? moneyFormatter({ amount: item.price, currency_code: currency }) + ' / Job' : ''}
                  td.col-amount.num #{item.total != null ? moneyFormatter({ amount: item.total, currency_code: currency }) : (item.price != null && item.quantity != null ? moneyFormatter({ amount: item.price * item.quantity, currency_code: currency }) : '')}
              if chunk.length === 0
                tr
                  td(colspan='5' style='text-align:center') 無項目
          if pageIndex === itemChunks.length - 1
            .summary-wrap
              .summary-block
                .summary-row.subtotal
                  span.summary-label 合共港幣：
                  span.summary-value #{moneyFormatter({ amount: subTotal, currency_code: currency })}
                .summary-row
                  span.summary-label 折扣%：
                  span.summary-value #{discount}%
                .summary-row
                  span.summary-label 折扣金額：
                  span.summary-value #{moneyFormatter({ amount: discountTotal, currency_code: currency })}
                .summary-row.grand
                  span.summary-label 總金額：
                  span.summary-value #{moneyFormatter({ amount: total, currency_code: currency })}
            .notes-block
              .notes-title 注：
              .notes-content
                | 1) 此報價有效期為90天
                if model.notes
                  br
                  | #{model.notes}
            .signature-section
              .prepared-by-row
                span.prepared-by-label 制單人：
                if model.createdBy && model.createdBy.name
                  span #{model.createdBy.name}
                else
                  span.prepared-by-space
              table.signature-table
                tr
                  td.sig-left
                    .issuer-block
                      .issuer-name-line 核實者
                      .issuer-name-line 同意及確定
                      .issuer-stamp
                      .signature-stamp-label 公司簽署及蓋章
                  td.sig-right
                    .issuer-block
                      .issuer-name-line 發出者
                      .issuer-name-line 超越工程公司
                      .issuer-stamp
                      .signature-stamp-label 公司簽署及蓋章
            .end-marker End
        .footer-section
          .footer-line-1 新界火炭坳背灣街14-24號金豪工業大廈第2期14樓G&H室 電話: 2776 4793, 2756 7579 傳真: 2776 4796
          .footer-line-2 Flat G&H, 14/F, Phase 2, Kin Ho Ind. Bldg., 14-24 Au Pui Wan St., Fotan, N.T. Tel: 2776 4793, 2756 7579 Fax: 2776 4796
